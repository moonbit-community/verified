predicate[T : Compare] sorted_desc(arr : FixedArray[T]) {
  ∀ k : Int,
    (0 <= k && k + 1 < arr.length()) → arr[k + 1] <= arr[k]
}

predicate[T : Compare] prefix_dominates_suffix(arr : FixedArray[T], i : Int) {
  ∀ k : Int, ∀ l : Int,
    (0 <= k && k < i && k < l && l < arr.length()) →
      arr[l] <= arr[k]
}

predicate[T : Compare] suffix_head_dominates(arr : FixedArray[T], j : Int) {
  ∀ k : Int, (j <= k && k < arr.length()) → arr[k] <= arr[j]
}
