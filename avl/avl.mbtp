///|
predicate[T : Compare] insert_elements_mem_post(
  a : T,
  b : T,
  s1 : Fset[T],
  s2 : Fset[T],
  z : T
) {
  s1.add(b).union(s2).add(a).mem(z) ==
  s1.union(s2).add(a).add(b).mem(z)
}

///|
lemma[T : Compare] insert_elements_mem(
  a : T,
  b : T,
  s1 : Fset[T],
  s2 : Fset[T],
  z : T
) where {
  proof_ensure: insert_elements_mem_post(a, b, s1, s2, z),
} {
  proof_assert insert_elements_mem_post(a, b, s1, s2, z)
}

predicate[T : Compare] insert_elements_eq(a : T, b : T, s1 : Fset[T], s2 : Fset[T]) {
  s1.add(b).union(s2).add(a).eq(s1.union(s2).add(a).add(b))
}

///|
lemma[T : Compare] insert_elements_eq_lemma(a : T, b : T, s1 : Fset[T], s2 : Fset[T]) where {
  proof_ensure: insert_elements_eq(a, b, s1, s2),
} {
  proof_assert insert_elements_eq(a, b, s1, s2)
}

predicate[T : Compare] insert_elements_eq_right(a : T, b : T, s1 : Fset[T], s2 : Fset[T]) {
  s1.union(s2.add(b)).add(a).eq(s1.union(s2).add(a).add(b))
}

///|
lemma[T : Compare] insert_elements_eq_right_lemma(a : T, b : T, s1 : Fset[T], s2 : Fset[T]) where {
  proof_ensure: insert_elements_eq_right(a, b, s1, s2),
} {
  proof_assert insert_elements_eq_right(a, b, s1, s2)
}

///|
predicate[T : Compare] delete_left_eq(x : T, y : T, s1 : Fset[T], s2 : Fset[T]) {
  s1.union(s2).add(y).remove(x).eq(s1.remove(x).union(s2).add(y))
}

///|
lemma[T : Compare] delete_left_eq_lemma(x : T, y : T, s1 : Fset[T], s2 : Fset[T]) where {
  proof_require: x < y,
  proof_require: all_gt(y, s2),
  proof_ensure: delete_left_eq(x, y, s1, s2),
} {

}

///|
predicate[T : Compare] delete_right_eq(x : T, y : T, s1 : Fset[T], s2 : Fset[T]) {
  s1.union(s2).add(y).remove(x).eq(s1.union(s2.remove(x)).add(y))
}

///|
lemma[T : Compare] delete_right_eq_lemma(x : T, y : T, s1 : Fset[T], s2 : Fset[T]) where {
  proof_require: y < x,
  proof_require: all_lt(s1, y),
  proof_ensure: delete_right_eq(x, y, s1, s2),
} {

}

///|
predicate[T : Compare] delete_eq_eq(x : T, s1 : Fset[T], s2 : Fset[T]) {
  s1.union(s2).add(x).remove(x).eq(s1.union(s2))
}

///|
lemma[T : Compare] delete_eq_eq_lemma(x : T, s1 : Fset[T], s2 : Fset[T]) where {
  proof_require: all_lt(s1, x),
  proof_require: all_gt(x, s2),
  proof_ensure: delete_eq_eq(x, s1, s2),
} {

}
