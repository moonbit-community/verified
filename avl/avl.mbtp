predicate[T : Compare] double_rotation_mem_rl_post(
  a : T,
  b : T,
  c : T,
  s1 : Fset[T],
  s2 : Fset[T],
  s3 : Fset[T],
  s4 : Fset[T],
  z : T
) {
  s1.union(s2).add(b).union(s3.union(s4).add(c)).add(a).mem(z) ==
  s1.union(s2.union(s3).add(a).union(s4).add(c)).add(b).mem(z)
}

///|
lemma[T : Compare] double_rotation_mem_rl(
  a : T,
  b : T,
  c : T,
  s1 : Fset[T],
  s2 : Fset[T],
  s3 : Fset[T],
  s4 : Fset[T],
  z : T
) where {
  proof_ensure: double_rotation_mem_rl_post(a, b, c, s1, s2, s3, s4, z),
